# blur_chain.scn вҖ” жҙ»й«”зүҷ: иҰӘжүӢеңЁ canvas жҺҘ RenderTargetвҶ’Blur йҸҲ, иӯү lane I е…©жўқжүҝйҮҚз·ҡ:
#   (1) Texture2D gather зӣҙйҖҡзңҹзҡ„йҖҡеҲ° Blur ијёе…Ҙ вҶ’ ж”№ Blur Size з•«йқўеғҸзҙ и®Ҡ (assert_diff);
#   (2) defaultDrawTarget йҒёжңҖдёӢжёё tex sink (Blur) иҖҢйқһдёҠжёё RenderTarget (еҗҰеүҮ filter зңӢдёҚиҰӢ)гҖӮ
#
# default ең– = defaultParticleGraph (RadialPoints#1 / ParticleSystem#2 / Turbulence#6 /
# DrawPoints#7 / AudioReaction#8, nextChildId=104)гҖӮжҲ‘еҖ‘еңЁз©әзҷҪиҷ•еҠ  RenderTarget#104 + Blur#105,
# жҠҠж—ўжңү DrawPoints#7.out вҶ’ RenderTarget#104.command вҶ’ Blur#105.Image, Blur жҲҗзӮәжңҖдёӢжёё tex sinkгҖӮ
#
# RED йқў: жҠҠжңҖеҫҢ assert_diff ж”№жҲҗ assert_same вҶ’ еҝ…зҙ… (ж”№ Size еғҸзҙ и®Ҡ = blur gather еңЁи·‘зҡ„зӣҙжҺҘиӯүж“ҡ)гҖӮ

# --- еҠ  RenderTarget (з©әзҷҪеҸійҚө, clear еҚҖ 250,240 вҖ” node1/node2 д№Ӣй–“дёӢж–№) ---
do rclick 250 240
wait 0.4
assert_map_has ctx:add_node_bg
do click @ctx:add_node_bg
wait 0.4
do click @bgctx:add:RenderTarget
wait 0.5
assert_state '[.lib.symbols[].children[] | select(.id == 104)] | length == 1'
echo rendertarget-104-spawned

# --- еҠ  Blur (з©әзҷҪеҸійҚө, clear еҚҖ 470,250 вҖ” node2 дёӢж–№еҸіеҒҙ) ---
do rclick 470 250
wait 0.4
assert_map_has ctx:add_node_bg
do click @ctx:add_node_bg
wait 0.4
do click @bgctx:add:Blur
wait 0.5
assert_state '[.lib.symbols[].children[] | select(.id == 105)] | length == 1'
echo blur-105-spawned

# --- жҺҘз·ҡ (output pin вҶ’ input pin) ---
# DrawPoints#7.out[pin 702] вҶ’ RenderTarget#104.command[pin 10401]
do drag @pin:702 @pin:10401
wait 0.3
# RenderTarget#104.out[pin 10402] вҶ’ Blur#105.Image[pin 10501]
do drag @pin:10402 @pin:10501
wait 0.3
# е…©жўқж–°йҖЈз·ҡйғҪе»әз«Ӣ (root йҖЈз·ҡж•ё: default 3 + 2 = 5)
assert_state '[.lib.symbols[] | select(.id == "Root") | .connections[]] | length == 5'
echo chain-connected-7to104to105

# --- з•«йқў: Blur жҳҜжңҖдёӢжёё tex sink вҶ’ output window йЎҜзӨә blur еҫҢз•«йқў, жҚ•дёҖе№Җ ---
wait 0.6
capture clean blurred
echo captured-blurred-output

# --- ж”№ Blur Size вҶ’ з•«йқўеғҸзҙ еҝ…и®Ҡ (blur еҚҠеҫ‘и®Ҡ = gather зңҹзҡ„еңЁи·‘) ---
# йҒё Blur#105 (жЁҷйЎҢеҲ—) вҶ’ Inspector жӢ– Size ж»‘жЎҝеҫҖеҸі (param:Size)
do click @node:105^
wait 0.4
do drag @param:Size +60 +0
wait 0.6
assert_diff blurred
echo size-change-moves-pixels
