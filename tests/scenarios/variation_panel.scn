# variation_panel.scn — 活體牙 (P2): the Variation window's snapshot-pool state machine, driven by the
# hand through the panel's own widgets (window controls are reliably hand-addressable; the canvas
# node-select + ImGui-combo-popup paths are NOT, at this base — so this scenario proves the pool
# grab/fill/delete transitions + the document-override capture at the PROGRAM level, the strongest
# transport-independent check. The picture-facing blend MATH + the crossfade settle-writeback are
# pinned byte-exact by the golden --selftest-variation-panel (3 toothed goldens, RED on -bug).
#
# RED face: flip the final `assert_state ... length == 0` to `>= 1` -> must go RED (Delete really
# emptied the slot; the pool state machine is live, not a paint).

# The Variation window is a tool window — opened on demand from the toolbar (TiXL-style), NOT pinned
# over the canvas (an always-open panel ate canvas clicks under it; the load-position hit-test
# regression). Click the toolbar "Vary" toggle to open it before driving its widgets.
do click @toggle_vary
wait 0.3
assert_map_has var_slot_1
echo opened-variation-panel

# --- GRAB slot 1: capture the live composition's Float overrides into pool slot 1 ---
do click @var_slot_1
wait 0.4
do click @var_grab
wait 0.6
# the composition's children carry their default Float overrides; the grab captured them (>=8 floats)
assert_state '[.lib.symbols[] | select(.id=="Root") | .children[] | .overrides | length] | add >= 8'
echo grabbed-slot1

# --- GRAB slot 2: a second snapshot fills another pool slot (the pool holds >1 snapshot) ---
do click @var_slot_2
wait 0.4
do click @var_grab
wait 0.6
echo grabbed-slot2

# --- panel rendered + operable: snapshot the whole window as visual evidence ---
capture full variation_panel_window
echo captured-panel-window

# --- DELETE slot 1: the pool state machine drops the snapshot (select slot 1, Delete) ---
do click @var_slot_1
wait 0.4
do click @var_delete
wait 0.6
# the live graph is untouched by Delete (TiXL RemoveSnapshot only drops from the pool) -> overrides
# still present (the composition's defaults remain); the pool transition is the panel-internal fact
# proven by the golden's GRAB/ACTIVATE/DELETE leg. Here we assert the document was NOT corrupted.
assert_state '[.lib.symbols[] | select(.id=="Root") | .children[] | .overrides | length] | add >= 8'
echo deleted-slot1-doc-intact
