# filter_wave3.scn вҖ” жҙ»й«”зүҷ (lane F3): иҰӘжүӢжҺҘ RenderTargetвҶ’Tint йҸҲ (Tint = filter wave 3 д»ЈиЎЁ),
# иӯү F3 зҡ„е–®ијёе…Ҙ Texture2D gather зӣҙйҖҡз·ҡе’Ң defaultDrawTarget йҒёжңҖдёӢжёё tex sink:
#   (1) Texture2D gather зӣҙйҖҡжҠҠ RenderTarget зҡ„ијёеҮәйӨөйҖІ Tint.Image вҶ’ ж”№ Tint Amount з•«йқўеғҸзҙ и®Ҡ;
#   (2) defaultDrawTarget йҒёжңҖдёӢжёё tex sink (Tint#105) иҖҢйқһдёҠжёё RenderTarget#104.
#
# default ең– = defaultParticleGraph (RadialPoints#1 / ParticleSystem#2 / TurbulenceForce#6 /
# DrawPoints#7 / AudioReaction#8, nextChildId=104). еҠ  RenderTarget#104 + Tint#105;
# DrawPoints#7.out вҶ’ RenderTarget#104.command вҶ’ Tint#105.Image. Tint жҲҗзӮәжңҖдёӢжёё tex sink.
#
# capture clean = Metal render ијёеҮә (filter йҸҲжҺҘйҖІ render, еҗҢ blur_chain зҜ„ејҸ).
# RED йқў: жҠҠжңҖеҫҢ assert_diff ж”№жҲҗ assert_same вҶ’ еҝ…зҙ… (ж”№ Amount еғҸзҙ и®Ҡ = gather еңЁи·‘зҡ„зӣҙжҺҘиӯүж“ҡ).

# --- еҠ  RenderTarget#104 (з©әзҷҪеҸійҚө) ---
do rclick 250 240
wait 0.4
assert_map_has ctx:add_node_bg
do click @ctx:add_node_bg
wait 0.4
do click @bgctx:add:RenderTarget
wait 0.5
assert_state '[.lib.symbols[].children[] | select(.id == 104)] | length == 1'
echo rendertarget-104-spawned

# --- еҠ  Tint#105 (з©әзҷҪеҸійҚө) ---
do rclick 470 250
wait 0.4
assert_map_has ctx:add_node_bg
do click @ctx:add_node_bg
wait 0.4
do click @bgctx:add:Tint
wait 0.5
assert_state '[.lib.symbols[].children[] | select(.id == 105)] | length == 1'
echo tint-105-spawned

# --- жҺҘз·ҡ ---
# DrawPoints#7.out[pin 702] вҶ’ RenderTarget#104.command[pin 10401]
do drag @pin:702 @pin:10401
wait 0.3
# RenderTarget#104.out[pin 10402] вҶ’ Tint#105.Image[pin 10501]
do drag @pin:10402 @pin:10501
wait 0.3
# е…©жўқж–°йҖЈз·ҡе»әз«Ӣ (root йҖЈз·ҡж•ё: default 3 + 2 = 5)
assert_state '[.lib.symbols[] | select(.id == "Root") | .connections[]] | length == 5'
echo chain-connected-7to104to105-tint

# --- з•«йқў: Tint жҳҜжңҖдёӢжёё tex sink вҶ’ output window йЎҜзӨә tint еҫҢз•«йқў, жҚ•дёҖе№Җ ---
wait 0.6
capture clean tinted_base
echo captured-tint-base-output

# --- ж”№ Tint Amount вҶ’ з•«йқўеғҸзҙ еҝ…и®Ҡ (tint еј·еәҰи®Ҡ = gather зңҹзҡ„еңЁи·‘) ---
# йҒё Tint#105 (жЁҷйЎҢеҲ—) вҶ’ Inspector жӢ– Amount ж»‘жЎҝеҫҖеҸі (param:Amount)
do click @node:105^
wait 0.4
do drag @param:Amount +60 +0
wait 0.6
assert_diff tinted_base
echo amount-change-moves-pixels
