digraph G
{
FireOnStart [type="vuo.event.fireOnStart" version="1.0.0" label="Fire on Start|<refresh>refresh\l|<started>started\r" pos="-1010,-155" fillcolor="lime" _started_eventThrottling="enqueue"];

