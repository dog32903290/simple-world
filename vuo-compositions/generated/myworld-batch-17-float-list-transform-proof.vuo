FireOnStart:started -> FloatListA:refresh;
FireOnStart:started -> FloatListB:refresh;

FireOnDisplayRefresh:requestedFrame -> ProofImage:renderTick;
FireOnDisplayRefresh:requestedFrame -> RenderWindow:refresh;

FloatListA:list -> CombineFloatLists:inputList1;
FloatListB:list -> CombineFloatLists:inputList2;
CombineFloatLists:selected -> RemapFloatList:floatList;
CombineFloatLists:selected -> ProofImage:combinedList;
RemapFloatList:result -> ProofImage:remappedList;

ProofImage:image -> RenderWindow:image;
ProofImage:image -> SaveImage:saveImage;
