FloatListA [type="vuo.list.make.3.VuoReal" version="2.0.0" label="Float List A|<refresh>refresh\l|<1>1\l|<2>2\l|<3>3\l|<list>list\r" pos="-810,-160" fillcolor="#868C8D" _1="0" _2="0.5" _3="1"];

FloatListB [type="vuo.list.make.2.VuoReal" version="2.0.0" label="Float List B|<refresh>refresh\l|<1>1\l|<2>2\l|<list>list\r" pos="-810,45" fillcolor="#868C8D" _1="0.25" _2="0.75"];

