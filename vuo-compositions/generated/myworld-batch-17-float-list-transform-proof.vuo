ProofImage [type="my.numbers.batch.batch17FloatListTransformProof" version="1.0.0" label="my_Batch17FloatListTransformProof|<renderTick>renderTick\l|<combinedList>combinedList\l|<remappedList>remappedList\l|<width>width\l|<height>height\l|<image>Image\r" pos="345,-55" fillcolor="#9F008A" _width="960" _height="540"];

RenderWindow [type="vuo.image.render.window2" version="4.0.0" label="Batch 17 Float List Transform|<refresh>refresh\l|<image>image\l|<setWindowDescription>setWindowDescription\l|<updatedWindow>updatedWindow\r" pos="865,-55" fillcolor="blue" _updatedWindow_eventThrottling="enqueue"];

SaveImage [type="vuo.image.save2" version="2.0.0" label="Save Image|<refresh>refresh\l|<url>url\l|<saveImage>saveImage\l|<ifExists>ifExists\l|<format>format\l|<done>done\r" pos="865,-285" fillcolor="orange" _url="\"\\/Users\\/chenbaiwei\\/Desktop\\/vibe coding\\/simple_world\\/artifacts\\/vuo_cli\\/batch-17-float-list-transform-vuo-save\"" _ifExists="1" _format="\"PNG\""];

