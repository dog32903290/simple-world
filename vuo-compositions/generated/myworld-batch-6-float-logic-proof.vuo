ProofImage [type="my.numbers.batch.batch6FloatLogicProof" version="1.0.0" label="my_Batch6FloatLogicProof|<renderTick>renderTick\l|<isGreaterValue>isGreaterValue\l|<pickFloatValue>pickFloatValue\l|<tryParseValue>tryParseValue\l|<valueToRateValue>valueToRateValue\l|<width>width\l|<height>height\l|<image>Image\r" pos="190,35" fillcolor="#9F008A" _width="960" _height="540"];

