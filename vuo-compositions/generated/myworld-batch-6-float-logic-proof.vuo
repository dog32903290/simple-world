FireOnStart:started -> MakeFloatList:refresh;
FireOnStart:started -> IsGreater:value;
FireOnStart:started -> TryParse:string;
FireOnStart:started -> ValueToRate:value;

FireOnDisplayRefresh:requestedFrame -> ProofImage:renderTick;
FireOnDisplayRefresh:requestedFrame -> RenderWindow:refresh;

MakeFloatList:list -> PickFloat:floatValues;
IsGreater:result -> ProofImage:isGreaterValue;
PickFloat:selected -> ProofImage:pickFloatValue;
TryParse:result -> ProofImage:tryParseValue;
ValueToRate:result -> ProofImage:valueToRateValue;
ProofImage:image -> RenderWindow:image;
ProofImage:image -> SaveImage:saveImage;
