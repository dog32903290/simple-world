ColorsToListA [type="my.numbers.floats.basic.colorsToList" version="1.0.0" label="Colors List A|<color1>color1\l|<color2>color2\l|<color3>color3\l|<inputCount>inputCount\l|<result>Result\r" pos="-680,45" fillcolor="#868C8D" _color2="\{\"r\":1,\"g\":0,\"b\":0,\"a\":1\}" _color3="\{\"r\":0,\"g\":1,\"b\":0,\"a\":1\}" _inputCount="3"];

