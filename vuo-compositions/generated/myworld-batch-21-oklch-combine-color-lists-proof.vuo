ProofImage [type="my.numbers.batch.batch21OklchCombineColorListsProof" version="1.0.0" label="my_Batch21OklchCombineColorListsProof|<renderTick>renderTick\l|<oklchColor>oklchColor\l|<combinedList>combinedList\l|<width>width\l|<height>height\l|<image>Image\r" pos="300,15" fillcolor="#9F008A" _width="960" _height="540"];

RenderWindow [type="vuo.image.render.window2" version="4.0.0" label="Batch 21 OKLCh Combine Color Lists|<refresh>refresh\l|<image>image\l|<setWindowDescription>setWindowDescription\l|<updatedWindow>updatedWindow\r" pos="880,15" fillcolor="blue" _updatedWindow_eventThrottling="enqueue"];

SaveImage [type="vuo.image.save2" version="2.0.0" label="Save Image|<refresh>refresh\l|<url>url\l|<saveImage>saveImage\l|<ifExists>ifExists\l|<format>format\l|<done>done\r" pos="880,-220" fillcolor="orange" _url="\"\\/Users\\/chenbaiwei\\/Desktop\\/vibe coding\\/simple_world\\/artifacts\\/vuo_cli\\/batch-21-oklch-combine-color-lists-vuo-save\"" _ifExists="1" _format="\"PNG\""];

