.DS_Store

# Local caches
.pytest_cache/
__pycache__/
*.pyc

# Local proof output that may contain screenshots/executables.
/artifacts/
/logs/

# Donor source trees and downloaded SDK/installers stay local.
/external/

# Vendored metal-cpp + imgui donor trees and CMake build output stay local.
/app/third_party/
/app/build/

# Agent-verification output (eye/ears/hands captures) — products, not source.
/app/.eye/

# Dear ImGui runtime layout — regenerated wherever the binary is launched (cwd-dependent).
imgui.ini

# Local virtual environments and dependency caches.
venv/
.venv/
node_modules/

# Git worktrees for isolated parallel feature branches (UI branch etc.). The
# vendored deps (app/third_party) + donor trees (external/) are gitignored, so
# each worktree symlinks them back to the main checkout after creation.
/.worktrees/

